# Copy this file to .env and set your secret key
# Generate a secure key: python3 -c "import secrets; print(secrets.token_hex(32))"

SEARXNG_SECRET=your-secret-key-change-in-production

# --- Tavily (optional, additive search provider) ---
# NOTE: These Tavily vars are NOT used by the SearxNG Docker container.
# Set them in your shell environment or MCP server "env" config block.
# Get your API key at https://app.tavily.com (1,000 free credits/month)
# TAVILY_API_KEY=tvly-YOUR_API_KEY
# SEARCH_PROVIDER=searxng  # 'searxng' (default) or 'tavily'
